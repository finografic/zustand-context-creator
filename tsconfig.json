{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "allowJs": true,
    "strict": true,
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "verbatimModuleSyntax": true
  },
  "include": ["**/*.ts", "**/*.tsx", "tsup.config.ts", "vitest.config.ts", "tests/**/*"],
  "exclude": ["src/utils/examples/**/*", "node_modules", "dist"]
}
