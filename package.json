{
  "name": "@finografic/zustand-context-creator",
  "type": "module",
  "version": "0.3.1",
  "packageManager": "pnpm@10.0.0",
  "description": "Fingorafic Zustax - Zustand Context Creator",
  "author": {
    "name": "Justin",
    "email": "justin.blair.rankin@gmail.com",
    "url": "http://finografic.github.com/cv-justin-rankin"
  },
  "license": "MIT",
  "keywords": [
    "zustex",
    "zustand",
    "context"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "========== DEV": "=======================================================",
    "watch": "tsup --format esm,cjs --watch",
    "·········· BUILD": "·····················································",
    "build": "tsup --format esm,cjs --clean --dts",
    "·········· LINTING": "···················································",
    "lint": "eslint .",
    "lint.fix": "eslint . --fix",
    "·········· PUBLISH.GITHUB": "·····················································",
    "prepublish.github": "pnpm build && git add dist/** && git commit -m \"chore: update generated files\" || true",
    "publish.github.patch": "pnpm prepublish.github && dotenvx run -- pnpm version patch && pnpm publish --registry https://npm.pkg.github.com",
    "publish.github.minor": "pnpm prepublish.github && dotenvx run -- pnpm version minor && pnpm publish --registry https://npm.pkg.github.com",
    "publish.github.major": "pnpm prepublish.github && dotenvx run -- pnpm version major && pnpm publish --registry https://npm.pkg.github.com",
    "·········· REGISTRIES": "··············································",
    "view.registry.gitub": "dotenvx run -- pnpm view @finografic/zustand-context-creator --registry=https://npm.pkg.github.com",
    "·········· UPDATE.DEPS": "·····················································",
    "upgrade.deps.v1": "pnpm update --latest",
    "upgrade.deps.all": "node scripts/update-deps.mjs",
    "·········· RULES": "·············································",
    "rules:install": "pnpm exec install-cursor-rules",
    "rules:sync": "pnpm exec install-cursor-rules",
    "·········· UTILS": "·····················································",
    "typecheck": "tsc --noEmit",
    "·········· HOOKS": "·····················································",
    "prepack": "pnpm build",
    "prepare": "simple-git-hooks"
  },
  "peerDependencies": {
    "react": "^18.0.0",
    "zustand": "^4.0.0 || ^5.0.0"
  },
  "devDependencies": {
    "@antfu/eslint-config": "6.4.2",
    "@antfu/ni": "24.3.0",
    "@dotenvx/dotenvx": "1.51.1",
    "@finografic/ai-rules": "0.3.0",
    "@finografic/eslint-config": "9.18.4",
    "@types/node": "22.15.17",
    "@types/react": "^18.3.12",
    "eslint": "^9.39.1",
    "lint-staged": "^16.2.7",
    "prettier": "3.7.4",
    "simple-git-hooks": "^2.13.1",
    "tsup": "8.4.0",
    "tsx": "^4.21.0",
    "typescript": "5.8.3"
  },
  "simple-git-hooks": {
    "pre-commit": "npx lint-staged"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,mjs,cjs}": [
      "eslint --fix"
    ]
  }
}
