{
  "name": "@finografic/zustand-context-creator",
  "version": "1.0.0",
  "description": "Fingorafic Zustax - Zustand Context Creator",
  "keywords": [
    "context",
    "zustand",
    "zustex"
  ],
  "license": "MIT",
  "author": {
    "name": "Justin",
    "email": "justin.blair.rankin@gmail.com",
    "url": "http://finografic.github.com/cv-justin-rankin"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/finografic/zustand-context-creator.git"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "scripts": {
    "========== DEV": "=======================================================",
    "watch": "tsup --format esm,cjs --watch",
    "·········· BUILD": "·····················································",
    "build": "tsup --format esm,cjs --clean --dts",
    "·········· LINTING": "···················································",
    "lint": "oxlint -c oxlint.config.ts",
    "lint:fix": "eslint . --fix",
    "lint:ci": "oxlint -c oxlint.config.ts --quiet",
    "·········· FORMATTING": "··················································",
    "format:check": "oxfmt --check",
    "format:fix": "oxfmt",
    "·········· PUBLISH:GITHUB": "·····················································",
    "prepublish:github": "pnpm build && git add dist/** && git commit -m \"chore: update generated files\" || true",
    "publish:github:gh:patch": "pnpm prepublish:github && dotenvx run -- pnpm version patch && pnpm publish --registry https://npm.pkg.github.com && pnpm run publish:github:gh:post",
    "publish:github:gh:minor": "pnpm prepublish:github && dotenvx run -- pnpm version minor && pnpm publish --registry https://npm.pkg.github.com && pnpm run publish:github:gh:post",
    "publish:github:gh:major": "pnpm prepublish:github && dotenvx run -- pnpm version major && pnpm publish --registry https://npm.pkg.github.com && pnpm run publish:github:gh:post",
    "publish:github:gh": "pnpm publish --registry https://npm.pkg.github.com && pnpm run publish:github:gh:post",
    "publish:github:gh:post": "git push origin --tags && gh release create \"$(git describe --tags --abbrev=0)\" --title \"$(git describe --tags --abbrev=0)\" --notes \"Release $(git describe --tags --abbrev=0)\"",
    "·········· REGISTRIES": "··············································",
    "view:registry:gitub": "dotenvx run -- pnpm view @finografic/zustand-context-creator --registry=https://npm.pkg.github.com",
    "·········· UPDATE:DEPS": "·····················································",
    "upgrade:deps:v1": "pnpm update --latest",
    "upgrade:deps:all": "node scripts/update-deps.mjs",
    "·········· RULES": "·············································",
    "rules:install": "pnpm exec install-cursor-rules",
    "rules:sync": "pnpm exec install-cursor-rules",
    "·········· TESTING": "·····················································",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "·········· UTILS": "·····················································",
    "typecheck": "tsc --noEmit",
    "·········· HOOKS": "·····················································",
    "prepack": "pnpm build",
    "prepare": "husky",
    "update:oxc-config": "pnpm update @finografic/oxc-config --latest && pnpm update oxfmt --latest && pnpm update oxlint --latest"
  },
  "devDependencies": {
    "@commitlint/cli": "latest",
    "@commitlint/config-conventional": "latest",
    "@dotenvx/dotenvx": "1.51.1",
    "@finografic/ai-rules": "0.3.0",
    "@finografic/oxc-config": "^2.3.5",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@types/node": "24.12.2",
    "@types/react": "^18.3.12",
    "@vitest/coverage-v8": "^2.1.8",
    "@vitest/ui": "^2.1.8",
    "happy-dom": "^15.11.7",
    "husky": "latest",
    "jsdom": "^25.0.1",
    "lint-staged": "^16.2.7",
    "oxfmt": "^0.46.0",
    "oxlint": "^1.61.0",
    "oxlint-tsgolint": "^0.21.1",
    "tsup": "8.4.0",
    "tsx": "^4.21.0",
    "typescript": "5.8.3",
    "vitest": "^2.1.8"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "zustand": "^4.0.0 || ^5.0.0"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,mjs,cjs}": [
      "oxfmt --no-error-on-unmatched-pattern",
      "oxlint -c oxlint.config.ts --fix --no-error-on-unmatched-pattern"
    ],
    "*.md": [
      "oxfmt --no-error-on-unmatched-pattern",
      "oxlint -c oxlint.config.ts --fix --no-error-on-unmatched-pattern"
    ],
    "*.{json,jsonc,yml,yaml,toml}": [
      "oxfmt --no-error-on-unmatched-pattern"
    ]
  },
  "packageManager": "pnpm@10.0.0"
}
